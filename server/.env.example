# Hero Fighter Server Environment Variables
# Copy this file to .env and fill in values for production.

# Application secret for HMAC signature verification
# Must match the client-side appSecret in lib/config/app_config.dart
APP_SECRET=hero-fighter-secret-key-2024-dev-only

# Database path (SQLite)
DB_PATH=./game_stats.db

# Server port
PORT=3000

# UDP discovery port
UDP_PORT=3001
